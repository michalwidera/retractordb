# Przykładowy plik środowiskowy jednostki systemd xretractor (EnvironmentFile).
#
# OPCJONALNY — bez niego serwis używa domyślnej ścieżki pliku zapytań wbudowanej w
# jednostkę (RETRACTOR_QUERY_FILE z czasu budowy). Aby nadpisać BEZ edycji jednostki
# (która należy do paczki), skopiuj ten plik jako żywą konfigurację i odkomentuj klucz:
#
#   sudo cp /etc/retractor/service.env.example /etc/retractor/service.env
#   sudo systemctl restart xretractor
#
# Format: KEY=VALUE (składnia systemd EnvironmentFile — bez 'export', bez cudzysłowów
# wokół całości). Czytany PO Environment= w jednostce, więc nadpisuje wartość domyślną.

# Ścieżka pliku zapytań ładowanego przez serwis (ExecStart). Plik MUSI istnieć
# (pusty = tryb idle). Domyślnie wskazywany przez jednostkę plik kanoniczny.
# RETRACTOR_QUERY_FILE=/etc/retractor/startup.rql

# Tryb usługowego logowania (stderr -> journald) niezależnie od flagi --service:
# XRETRACTOR_SERVICE=1
