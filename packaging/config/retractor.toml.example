# Przykładowa konfiguracja usługi xretractor (RetractorDB).
#
# Pliki konfiguracyjne są OPCJONALNE — bez nich xretractor startuje z domyślnymi
# ustawieniami. Aby aktywować, skopiuj ten plik jako żywą konfigurację:
#
#   sudo cp /etc/retractor/retractor.toml.example /etc/retractor/retractor.toml
#
# Wyszukiwanie warstwowe (kolejna warstwa nadpisuje klucze poprzedniej):
#   1. /etc/retractor/retractor.toml                       (systemowa)
#   2. $XDG_CONFIG_HOME (lub ~/.config)/retractor/retractor.toml  (użytkownika)
# Jawny plik: xretractor --config /ścieżka/do/pliku.toml (wyłącza wyszukiwanie).

[storage]
# Domyślny katalog na artefakty (pliki danych strumieni, .desc, .meta).
# Stosowany wyłącznie gdy zestaw RQL nie zdefiniował własnej dyrektywy :STORAGE
# (dyrektywa w .rql ma pierwszeństwo). Końcowy '/' jest opcjonalny.
dir = "/var/lib/retractor"

# [service]
# Plik zapytań nadpisywany, gdy nowa instancja przekazuje zestaw działającemu serwisowi
# (xretractor wykrywa serwis, nadpisuje ten plik i zleca restart jednostki). Używany tylko
# jako fallback — w normalnym przebiegu serwis sam raportuje swój plik zapytań. MUSI być
# zgodny z argumentem ExecStart jednostki systemd (zmiana tutaj nie zmienia ExecStart).
# query_file = "/etc/retractor/startup.rql"
