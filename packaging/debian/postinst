#!/bin/sh
# postinst dla pakietu retractordb: tworzy użytkownika usługi i włącza jednostkę
# systemd (bez natychmiastowego startu — wystartuje przy następnym boocie).
set -e

case "$1" in
  configure)
    # Użytkownik systemowy 'retractor' (User=/Group= w jednostce).
    if ! getent passwd retractor >/dev/null 2>&1; then
      if command -v adduser >/dev/null 2>&1; then
        adduser --system --group --no-create-home --home /nonexistent \
          --gecos "RetractorDB service" retractor || true
      else
        useradd --system --user-group --no-create-home \
          --shell /usr/sbin/nologin retractor || true
      fi
    fi

    # Rejestracja jednostki w systemd (tylko gdy systemd działa).
    if [ -d /run/systemd/system ]; then
      systemctl daemon-reload || true
      systemctl enable xretractor.service || true
    fi
    ;;
esac

exit 0
