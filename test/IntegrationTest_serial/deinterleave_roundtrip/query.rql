# Tozsamosc okrezna przeplotu/rozplotu (cor:exact):
# c = sa#sb (delty 1/16 i 1/8 -> delta_c = 1/24, wzorzec B,A,A dla z = 2/3),
# a2 = c & 1/8  -> odzyskuje sa (argument = delta strumienia USUWANEGO),
# b2 = c % 1/16 -> odzyskuje sb.
# Theta (&) jest realizowana z jednoslotowym opoznieniem (rekord 0 all-null).

DECLARE a UINT STREAM sa, 1/16 FILE 'datafile1.txt'
DECLARE a UINT STREAM sb, 1/8 FILE 'datafile2.txt'

SELECT c[0] STREAM c FROM sa#sb

SELECT * STREAM a2 FROM c&1/8
SELECT * STREAM b2 FROM c%1/16
