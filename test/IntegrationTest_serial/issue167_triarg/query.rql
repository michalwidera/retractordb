SUBSTRAT 'memory'

DECLARE val INTEGER STREAM s1, 1 FILE 'data1.dat'
DECLARE val INTEGER STREAM s2, 1 FILE 'data2.dat'
DECLARE val INTEGER STREAM s3, 1 FILE 'data3.dat'
DECLARE val INTEGER STREAM s4, 1 FILE 'data4.dat'

SELECT s1[0]+s2[0]+s3[0] STREAM out1 FROM s1+s2+s3
SELECT s1[0]+s2[0]+s3[0] STREAM out2 FROM (s1#s2)#s3
SELECT s1[0]+s2[0]+s3[0] STREAM out3 FROM s1+(s2#s3)
SELECT s1[0]+s2[0]+s3[0]+s4[0] STREAM out4 FROM s1+s2+s3+s4
SELECT s1[0]+s2[0]+s3[0] STREAM out5 FROM s1#s2#s3